<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ============ Base app theme (DayNight) ============ -->
    <style name="Theme.NopoX" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="android:colorBackground">@color/bg_blue_dark</item>
        <item name="android:windowBackground">@color/bg_blue_dark</item>
        <item name="android:statusBarColor">@color/bg_blue_dark</item>
        <item name="android:navigationBarColor">@color/bg_blue_dark</item>
        <item name="colorAccent">@color/accent_color</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowAnimationStyle">@android:style/Animation.Activity</item>
    </style>

    <!-- ============ NoActionBar variant (used by MainActivity) ============ -->
    <style name="Theme.NopoX.NoActionBar" parent="Theme.NopoX">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>

    <!-- ============ Transparent theme (for TransparentActivity, dialogs) ============ -->
    <style name="Theme.Transparent" parent="Theme.NopoX.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:colorBackgroundCacheHint">@null</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <!-- ============ Splash theme ============ -->
    <style name="Theme.NopoX.Splash" parent="Theme.NopoX.NoActionBar">
        <item name="android:windowBackground">@color/bg_splash</item>
        <item name="android:statusBarColor">@color/bg_splash</item>
    </style>

    <!-- ============ Compose-bound text appearances (used by XML widgets) ============ -->
    <style name="TextAppearance.NopoX.Bold" parent="@android:style/TextAppearance">
        <item name="android:fontFamily">@font/nunito_bold</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.NopoX.SemiBold" parent="@android:style/TextAppearance">
        <item name="android:fontFamily">@font/nunito_semibold</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.NopoX.Regular" parent="@android:style/TextAppearance">
        <item name="android:fontFamily">@font/nunito_regular</item>
    </style>

    <style name="TextAppearance.NopoX.ExtraBold" parent="@android:style/TextAppearance">
        <item name="android:fontFamily">@font/nunito_extrabold</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- ============ Block screen text appearances ============ -->
    <style name="TextAppearance.NopoX.BlockScreen.Title" parent="TextAppearance.NopoX.Bold">
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="TextAppearance.NopoX.BlockScreen.Message" parent="TextAppearance.NopoX.SemiBold">
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="TextAppearance.NopoX.BlockScreen.Close" parent="TextAppearance.NopoX.Bold">
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="TextAppearance.NopoX.BlockScreen.Why" parent="TextAppearance.NopoX.SemiBold">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/accent_color</item>
    </style>

    <!-- ============ Widget text appearances ============ -->
    <style name="TextAppearance.NopoX.Widget.StopMe" parent="TextAppearance.NopoX.Bold">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="TextAppearance.NopoX.Widget.Streak" parent="TextAppearance.NopoX.ExtraBold">
        <item name="android:textSize">32sp</item>
        <item name="android:textColor">@color/white</item>
    </style>
</resources>
