<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ============ Base app theme (LIGHT / day mode) ============ -->
    <style name="Theme.NopoX" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="android:colorBackground">@color/light_bg</item>
        <item name="android:windowBackground">@color/light_bg</item>
        <item name="android:statusBarColor">@color/light_bg</item>
        <item name="android:navigationBarColor">@color/light_bg</item>
        <item name="colorAccent">@color/accent_color</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:windowAnimationStyle">@android:style/Animation.Activity</item>
    </style>

    <!-- ============ NoActionBar variant (used by MainActivity) ============ -->
    <style name="Theme.NopoX.NoActionBar" parent="Theme.NopoX">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>

    <!-- ============ Transparent theme (for TransparentActivity, dialogs) ============ -->
    <style name="Theme.Transparent" parent="Theme.NopoX.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:colorBackgroundCacheHint">@null</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <!-- ============ Splash theme ============ -->
    <style name="Theme.NopoX.Splash" parent="Theme.NopoX.NoActionBar">
        <item name="android:windowBackground">@color/bg_splash</item>
        <item name="android:statusBarColor">@color/bg_splash</item>
    </style>
</resources>
