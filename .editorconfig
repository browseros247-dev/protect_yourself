# =============================================================================
# EditorConfig — ensures consistent coding style across editors and IDEs.
# https://editorconfig.org
#
# This file is read by IntelliJ/Android Studio, VS Code, vim, emacs, and
# GitHub's web editor. It complements (but does not replace) ktlint and
# Detekt — those tools enforce project-specific rules at build time.
# =============================================================================

root = true   # Stop searching for .editorconfig in parent directories

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 140

# Kotlin — matches ktlint's default style
[*.kt]
indent_size = 4
continuation_indent_size = 8
max_line_length = 140
# ktlint: disabled rules (use // @formatter:off to override locally)
ij_kotlin_imports_layout = *
ij_kotlin_name_count_to_use_star_import = 999   # Never auto-star-import
ij_kotlin_name_count_to_use_star_import_for_members = 999

# Kotlin script files (Gradle)
[*.kts]
indent_size = 4
continuation_indent_size = 8
max_line_length = 200   # Gradle DSL lines tend to be longer

# XML (Android resources)
[*.{xml,html}]
indent_size = 4
max_line_length = 200

# YAML (GitHub Actions, Dependabot)
[*.{yml,yaml}]
indent_size = 2
max_line_length = 200

# JSON
[*.json]
indent_size = 2

# Markdown
[*.md]
trim_trailing_whitespace = false   # Markdown requires trailing 2 spaces for line breaks
max_line_length = off

# Shell scripts
[*.sh]
indent_size = 2
max_line_length = 120

# Properties files
[*.properties]
indent_size = 2
max_line_length = 200

# TOML (Gradle version catalog)
[*.toml]
indent_size = 2
max_line_length = 200
