<?xml version="1.0" encoding="utf-8"?>
<!--
  Block screen layout (matches original page_porn_block.xml minus AdMob banner + PU promo banner).

  CHANGES (block-screen motivation image + message UI/UX pass):
   - Motivation image: was fixed 200x200dp with no scaleType → squashed non-square images.
     Now uses adjustViewBounds + fitCenter with a maxHeight so aspect ratio is preserved
     and very tall images don't push the message off-screen.
   - Motivation image: added contentDescription for accessibility.
   - Block message: was 24sp → reduced to 20sp so longer custom messages still fit on
     one screen with the image + close button.
   - "Why" interaction: txtWhy now reads "Why am I seeing this?" / "Hide details" so the
     affordance is discoverable (was two TextViews both labeled "Why" — see PornBlockActivity).
   - txtWhyContainer: increased line spacing + maxLines so long explanations wrap cleanly
     instead of running off the screen.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_blue_dark">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:animateLayoutChanges="true"
            android:paddingTop="32dp"
            android:paddingBottom="120dp">

            <!-- App logo + name header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:padding="16dp">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@mipmap/ic_launcher"
                    android:importantForAccessibility="no"
                    android:visibility="visible" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="@string/app_name"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:fontFamily="@font/nunito_bold"
                    android:gravity="center"
                    android:visibility="visible" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="8dp" />

            <!-- Optional motivation image (user-uploaded in Settings) -->
            <!-- adjustViewBounds + fitCenter preserves aspect ratio. maxHeight
                 keeps the image from consuming the whole screen. -->
            <ImageView
                android:id="@+id/imgMotivation"
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:maxHeight="320dp"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginBottom="12dp"
                android:contentDescription="@string/block_screen_motivation_image_cd"
                android:visibility="gone" />

            <!-- Block message -->
            <TextView
                android:id="@+id/txtPageMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:text="@string/block_page_default_message"
                android:textSize="20sp"
                android:textColor="@color/white"
                android:fontFamily="@font/nunito_semibold"
                android:gravity="center"
                android:lineSpacingExtra="4sp"
                android:visibility="visible" />

            <!-- Optional rating prompt (shown after N blocks) -->
            <LinearLayout
                android:id="@+id/llRatingContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:orientation="vertical"
                android:paddingTop="36dp"
                android:paddingBottom="16dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/txtRatingMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/play_store_rating_message"
                    android:textSize="18sp"
                    android:textColor="@color/white"
                    android:fontFamily="@font/nunito_semibold"
                    android:gravity="center"
                    android:letterSpacing="0.03"
                    android:lineSpacingExtra="6sp" />

                <!-- NOTE: replace with RatingBar from com.willy.ratingbar library in Phase 3 -->
                <RatingBar
                    android:id="@+id/ratingBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_gravity="center"
                    android:numStars="5"
                    android:stepSize="1"
                    android:rating="0" />
            </LinearLayout>

            <!-- REMOVED: imgPuBanner (was PU promotion banner) -->
        </LinearLayout>
    </ScrollView>

    <!-- Bottom controls (anchored to bottom) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@color/bg_blue_dark">

        <!-- Why-detail text (shown when the user taps "Why am I seeing this?") -->
        <TextView
            android:id="@+id/txtWhyContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:text="@string/why"
            android:textSize="14sp"
            android:textColor="@color/sub_title_text_color"
            android:fontFamily="@font/nunito_semibold"
            android:gravity="center"
            android:letterSpacing="0.02"
            android:lineSpacingExtra="4sp"
            android:maxLines="4"
            android:ellipsize="end"
            android:visibility="gone" />

        <!-- "Why am I seeing this?" toggle -->
        <TextView
            android:id="@+id/txtWhy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="10dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:text="@string/why"
            android:textSize="15sp"
            android:textColor="@color/accent_color"
            android:fontFamily="@font/nunito_semibold"
            android:gravity="center"
            android:visibility="visible" />

        <FrameLayout
            android:id="@+id/txtCloseContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:background="@drawable/bg_orange_gradient">

            <TextView
                android:id="@+id/txtClose"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="@string/close"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:fontFamily="@font/nunito_bold"
                android:gravity="center"
                android:textAlignment="center" />
        </FrameLayout>

        <!-- REMOVED: adViewContainer (was AdMob banner container) -->
    </LinearLayout>
</FrameLayout>
