<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ============ Permissions ============ -->
    <!-- Original 22 permissions minus BILLING + AD_ID + INSTALL_REFERRER (paid/ads removed) -->

    <!-- Notifications (Android 13+) -->
    <uses-permission android:name="android.permission.ACCESS_NOTIFICATION_POLICY" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <!-- Foreground services -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Required for targetSdk 34+: foreground service types -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- System access -->
    <uses-permission android:name="android.permission.WRITE_SECURE_SETTINGS"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="com.android.alarm.permission.SET_ALARM" />

    <!-- Network -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Boot / startup -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Process management -->
    <uses-permission android:name="android.permission.KILL_BACKGROUND_PROCESSES" />
    <uses-permission android:name="android.permission.REORDER_TASKS" />

    <!-- Overlay / block screen -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Multi-user (signature-level, for some accessibility self-heal flows) -->
    <uses-permission android:name="android.permission.INTERACT_ACROSS_USERS_FULL"
        android:protectionLevel="signature"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.INTERACT_ACROSS_USERS"
        android:protectionLevel="signature"
        tools:ignore="ProtectedPermissions" />

    <!-- Wake / power -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Biometric -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.USE_FINGERPRINT" />

    <!-- BUG-07 fix: removed dead com.google.android.c2dm.permission.RECEIVE
         permission. Firebase Cloud Messaging was stripped from the build;
         keeping this permission is dead code + attracts Play Store review
         attention for no benefit. -->

    <!-- Query all packages (app list feature) -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <!-- ============ Queries (visibility for other apps) ============ -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
        </intent>
        <intent>
            <action android:name="android.intent.action.SENDTO" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
        </intent>
        <intent>
            <action android:name="android.intent.action.PICK" />
        </intent>
        <intent>
            <action android:name="android.intent.action.DIAL" />
        </intent>
        <intent>
            <action android:name="android.intent.action.TTS_SERVICE" />
        </intent>
        <intent>
            <action android:name="android.intent.action.GET_CONTENT" />
            <category android:name="android.intent.category.OPENABLE" />
            <data android:mimeType="*/*" />
        </intent>
        <intent>
            <action android:name="android.media.action.IMAGE_CAPTURE" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="https" />
        </intent>
        <intent>
            <action android:name="android.support.customtabs.action.CustomTabsService" />
        </intent>
    </queries>

    <!-- ============ Custom permission ============ -->
    <permission
        android:name="protect.yourself.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"
        android:protectionLevel="signature" />
    <uses-permission android:name="protect.yourself.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION" />

    <!-- ============ Application ============ -->
    <application
        android:name="protect.yourself.core.ProtectYourselfApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="${appLabel}"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ProtectYourself"
        android:largeHeap="true"
        android:isAccessibilityTool="true"
        android:appComponentFactory="androidx.core.app.CoreComponentFactory"
        tools:targetApi="33">

        <!-- ===== Activities ===== -->

        <!-- Main launcher activity -->
        <activity
            android:name="protect.yourself.features.mainActivityPage.MainActivity"
            android:exported="true"
            android:label="${appLabel}"
            android:launchMode="singleTask"
            android:screenOrientation="portrait"
            android:showOnLockScreen="true"
            android:theme="@style/Theme.ProtectYourself.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Custom scheme deep link -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:host="protectyourself" android:scheme="open" />
            </intent-filter>

            <!-- Standard Android App Links (replaces Branch.io) -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" />
                <data android:host="protectyourself.app.link" />
                <data android:host="protectyourself-alternate.app.link" />
            </intent-filter>
        </activity>

        <!-- Protected Accessibility Apps activity -->
        <activity
            android:name="protect.yourself.features.protectedApps.ProtectedAppsActivity"
            android:exported="false"
            android:label="Protected Accessibility Apps"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.ProtectYourself.NoActionBar" />

        <!-- Transparent activity for background overlays -->
        <activity
            android:name="protect.yourself.features.transparentPage.TransparentActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:theme="@style/Theme.Transparent" />

        <!-- In-app review activity -->
        <activity
            android:name="protect.yourself.features.ratingPage.inAppReview.InAppReviewActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:theme="@style/Theme.Transparent" />

        <!-- Porn block activity (block screen overlay) -->
        <activity
            android:name="protect.yourself.features.blockerPage.ui.PornBlockActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:launchMode="singleTop"
            android:screenOrientation="portrait"
            android:showOnLockScreen="true"
            android:theme="@style/Theme.ProtectYourself.NoActionBar" />

        <!-- Image cropper (CanHub library) — removed, dependency stripped -->
        <!-- <activity android:name="com.canhub.cropper.CropImageActivity" .../> -->

        <!-- ===== Services ===== -->

        <!-- BUG-07 fix: removed dead Firebase Messaging service declaration.
             The class doesn't exist (Firebase was stripped from the build).
             Keeping this declaration would cause ClassNotFoundException if an
             FCM intent ever arrived (it shouldn't, since FCM is removed, but
             the declaration is dead code regardless). -->

        <!-- Accessibility service (core blocking) -->
        <service
            android:name="protect.yourself.features.blockerPage.service.MyAccessibilityService"
            android:exported="true"
            android:label="${appLabel}"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter android:priority="100">
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_setting" />
        </service>

        <!-- VPN service (DNS blocking) -->
        <service
            android:name="protect.yourself.features.blockerPage.service.MyVpnService"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            android:permission="android.permission.BIND_VPN_SERVICE">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
            <meta-data
                android:name="android.net.VpnService.SUPPORTS_ALWAYS_ON"
                android:value="true" />
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="VPN DNS filtering for content blocking" />
        </service>

        <!-- ===== Broadcast Receivers ===== -->

        <!-- Connectivity change -->
        <receiver
            android:name="protect.yourself.commons.utils.broadcastReceivers.AppSystemActionReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter android:priority="999">
                <category android:name="android.intent.category.DEFAULT" />
                <action android:name="android.net.conn.CONNECTIVITY_CHANGE" />
            </intent-filter>
        </receiver>

        <!-- Boot + screen state (always-on) -->
        <receiver
            android:name="protect.yourself.commons.utils.broadcastReceivers.AppSystemActionReceiverAllTime"
            android:enabled="true"
            android:exported="true">
            <intent-filter android:priority="999">
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.REBOOT" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
                <action android:name="android.intent.action.SCREEN_ON" />
                <action android:name="android.intent.action.USER_PRESENT" />
            </intent-filter>
        </receiver>

        <!-- Package install/remove -->
        <receiver
            android:name="protect.yourself.commons.utils.broadcastReceivers.AppSystemActionReceiverAllTimeWithData"
            android:enabled="true"
            android:exported="true">
            <intent-filter android:priority="999">
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="android.intent.action.PACKAGE_ADDED" />
                <action android:name="android.intent.action.PACKAGE_REMOVED" />
                <data android:scheme="package" />
            </intent-filter>
        </receiver>

        <!-- Device admin (anti-uninstall) -->
        <receiver
            android:name="protect.yourself.features.blockerPage.utils.DeviceAdminUtils$MyDeviceAdminReceiver"
            android:exported="true"
            android:permission="android.permission.BIND_DEVICE_ADMIN">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
                <action android:name="android.app.action.DEVICE_ADMIN_DISABLE_REQUESTED" />
                <action android:name="android.app.action.DEVICE_ADMIN_DISABLED" />
                <action android:name="android.app.action.USER_ADDED" />
                <action android:name="android.app.action.USER_SWITCHED" />
            </intent-filter>
        </receiver>

        <!-- Stop Me widget -->
        <receiver
            android:name="protect.yourself.features.blockerPage.widget.StopMeWidget"
            android:exported="false"
            android:label="@string/stop_me">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/stop_me_widget_info" />
        </receiver>

        <!-- Streak widget -->
        <receiver
            android:name="protect.yourself.features.streakPage.widget.StreakWidget"
            android:exported="false"
            android:label="@string/streak">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/streak_widget_info" />
        </receiver>

        <!-- Stop Me alarm receiver (for session start/end) -->
        <receiver
            android:name="protect.yourself.commons.utils.broadcastReceivers.StopMeAlarmReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="protect_yourself.action.STOP_ME_START" />
                <action android:name="protect_yourself.action.STOP_ME_END" />
            </intent-filter>
        </receiver>

        <!-- ===== Content Providers ===== -->

        <!-- App file provider -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Image cropper file provider — removed, dependency stripped -->

        <!-- AndroidX startup — DISABLED to prevent crashes from auto-initializers
             that run BEFORE Application.onCreate(). Everything is initialized
             manually in ProtectYourselfApp.onCreate() with try/catch. -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <!-- Disable WorkManager auto-init (we use on-demand via WorkManager.getInstance) -->
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
            <!-- Disable ProcessLifecycle auto-init (we add observer manually) -->
            <meta-data
                android:name="androidx.lifecycle.ProcessLifecycleInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
            <!-- Disable EmojiCompat auto-init (not used) -->
            <meta-data
                android:name="androidx.emoji2.text.EmojiCompatInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
            <!-- Disable ProfileInstaller auto-init (not needed) -->
            <meta-data
                android:name="androidx.profileinstaller.ProfileInstallerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

    </application>

</manifest>
